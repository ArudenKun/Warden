<UserControl
    x:Class="Warden.Views.SetupView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:generic="using:System.Collections.Generic"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    xmlns:system="using:System"
    xmlns:warden="https://github.com/arudenkun/warden"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="warden:SetupViewModel"
    mc:Ignorable="d">
    <Grid RowDefinitions="*,Auto,Auto">
        <suki:GlassCard Grid.Row="0">
            <suki:GroupBox Header="{Binding Header}">
                <suki:SukiTransitioningContentControl
                    Name="CurrentView"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Content="{Binding Step}" />
            </suki:GroupBox>
        </suki:GlassCard>
        <suki:Stepper
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Index="{Binding StepIndex}">
            <suki:Stepper.Steps>
                <generic:List x:TypeArguments="system:String">
                    <x:String>Theme</x:String>
                    <x:String>Tools</x:String>
                </generic:List>
            </suki:Stepper.Steps>
        </suki:Stepper>
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="5">
            <Button
                Command="{Binding NextCommand}"
                Content="Next" />
            <Button
                Command="{Binding BackCommand}"
                Content="Back" />
        </StackPanel>
    </Grid>
</UserControl>