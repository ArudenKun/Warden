<UserControl
    x:Class="Warden.Views.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    xmlns:warden="https://github.com/arudenkun/warden"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="warden:SettingsViewModel"
    mc:Ignorable="d">
    <UserControl.Styles>
        <Style Selector="TextBlock.SettingsRowHeader">
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="20" />
        </Style>
        <Style Selector="StackPanel.SettingsRow">
            <Setter Property="Margin" Value="0, 12, 0,0" />
            <Setter Property="Orientation" Value="Vertical" />
            <Setter Property="Spacing" Value="6" />
        </Style>
        <Style Selector="TabControl">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <DockPanel>
                            <LayoutTransformControl
                                Name="PART_LayoutTransform"
                                DockPanel.Dock="{TemplateBinding TabStripPlacement}">
                                <ItemsPresenter
                                    Name="PART_ItemsPresenter"
                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                            </LayoutTransformControl>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ContentPresenter
                                    Name="PART_SelectedContentHost"
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Content="{TemplateBinding SelectedContent}"
                                    ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>
    <Grid
        Margin="24,24,24,24"
        RowDefinitions="Auto, *"
        RowSpacing="12">
        <DockPanel
            Grid.Row="0"
            LastChildFill="False">
            <TextBlock
                VerticalAlignment="Center"
                DockPanel.Dock="Left"
                FontSize="26"
                Text="{Binding DisplayName}" />
            <StackPanel
                DockPanel.Dock="Right"
                Orientation="Horizontal"
                Spacing="5">
                <Button
                    suki:ButtonExtensions.Icon="{LucideIconContent ArrowLeft}"
                    Command="{Binding BackCommand}"
                    Content="Back" />
                <Button
                    suki:ButtonExtensions.Icon="{LucideIconContent ArrowLeft}"
                    Command="{Binding RedoCommand}"
                    Content="Redo"
                    IsVisible="{Binding UndoManager.CanRedo}" />
                <Button
                    suki:ButtonExtensions.Icon="{LucideIconContent ArrowLeft}"
                    Command="{Binding UndoCommand}"
                    Content="Undo"
                    IsVisible="{Binding UndoManager.CanUndo}" />
            </StackPanel>
        </DockPanel>
        <TabControl Grid.Row="1">
            <TabItem Header="General">
                <StackPanel Classes="SettingsRow">
                    <warden:SettingsRow
                        Header="LogLevel"
                        IconKind="Logs">
                        <ComboBox
                            ItemsSource="{Binding LoggingOptions.LogEventLevel,
                                                  Converter={x:Static warden:EnumToEnumerableConverter.Instance},
                                                  Mode=OneTime}"
                            PlaceholderText="LogLevel"
                            SelectedItem="{Binding LoggingOptions.LogEventLevel}" />
                    </warden:SettingsRow>
                    <TextBlock
                        Classes="SettingsRowHeader"
                        Text="Updates" />
                    <warden:SettingsRow
                        Header="Check"
                        IconKind="CircleArrowUp">
                        <TextBox Watermark="Test" />
                    </warden:SettingsRow>
                    <warden:SettingsRow
                        Header="Check"
                        IconKind="CircleArrowUp">
                        <TextBox Watermark="" />
                    </warden:SettingsRow>
                </StackPanel>
            </TabItem>
            <TabItem Header="Appearance">
                <StackPanel Classes="SettingsRow">
                    <warden:SettingsRow
                        Description="The theme to use"
                        Header="Theme"
                        IconKind="SunMoon">
                        <ComboBox
                            ItemsSource="{Binding AppearanceOptions.Theme,
                                                  Converter={x:Static warden:EnumToEnumerableConverter.Instance},
                                                  Mode=OneTime}"
                            PlaceholderText="Theme"
                            SelectedItem="{Binding AppearanceOptions.Theme}" />
                    </warden:SettingsRow>
                    <warden:SettingsRow
                        Description="Test Description"
                        Header="Theme Color"
                        IconKind="Palette">
                        <ComboBox
                            ItemsSource="{Binding ColorThemes}"
                            SelectedItem="{Binding AppearanceOptions.ThemeColor}" />
                    </warden:SettingsRow>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>